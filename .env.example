# Server
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Payload CMS (min 32 characters)
PAYLOAD_SECRET=your-payload-secret-at-least-32-characters-long

# Database
DATABASE_URI=postgresql://user:password@localhost:5432/kids_places

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (email)
RESEND_API_KEY=re_...

# S3 Storage (Supabase or compatible)
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_REGION=eu-central-1
S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3

# Apify (web scraping)
APIFY_API_TOKEN=your-apify-token

# Admin API (min 32 characters)
ADMIN_API_KEY=your-admin-api-key-at-least-32-characters-long

# Analytics (optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
